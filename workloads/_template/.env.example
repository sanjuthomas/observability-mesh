# PORT_BLOCK selects a non-overlapping host port range for parallel local demos.
# Formula: host port = base port + PORT_BLOCK (see README port table).
#
# Copy to .env and adjust when creating a new workload:
#   cp .env.example .env

PORT_BLOCK=2000

# Platform (base + PORT_BLOCK)
OTEL_GRPC_PORT=6317
OTEL_HTTP_PORT=6318
OTEL_METRICS_PORT=10889
PROMETHEUS_PORT=11092
TEMPO_PORT=5200
GRAFANA_PORT=5000
OPENSEARCH_PORT=11200
OPENSEARCH_DASHBOARDS_PORT=7601
POSTGRES_PORT=7432
SLO_AUTHOR_PORT=11090
SLO_PROVISIONER_PORT=11097
ALERTMANAGER_PORT=11098

ALERTMANAGER_EMAIL_TO=observabilitymesh@sanju.org
ALERTMANAGER_SMTP_HOST=
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_FROM=alerts@sanju.org
ALERTMANAGER_SMTP_USER=
ALERTMANAGER_SMTP_PASSWORD=
ALERTMANAGER_SMTP_REQUIRE_TLS=true

# Workload identity + apps (base + PORT_BLOCK)
KEYCLOAK_PORT=11080
OPA_PORT=11181
MONGODB_PORT=29017
INSTRUCTION_PORT=11000
PAYMENT_PORT=11093
OFAC_PORT=11096
AUTHORIZATION_PORT=11094
SEQUENCE_PORT=11095
DEMO_HARNESS_PORT=11091

# SLO provisioner: datasource name referenced in postgres/seed-slos.sql
SLO_PROVISIONER_DATASOURCE_NAMES=my-workload-prometheus
