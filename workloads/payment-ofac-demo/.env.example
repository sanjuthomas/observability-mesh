# Default ports for payment-ofac-demo (PORT_BLOCK=0).
# Optional: cp .env.example .env — compose uses :- defaults when .env is absent.

PORT_BLOCK=0

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8889
PROMETHEUS_PORT=9092
TEMPO_PORT=3200
GRAFANA_PORT=3000
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
POSTGRES_PORT=5432
SLO_AUTHOR_PORT=9090
SLO_PROVISIONER_PORT=9097
ALERTMANAGER_PORT=9098

# Alertmanager email (required for outbound notifications)
ALERTMANAGER_EMAIL_TO=you@example.com
ALERTMANAGER_SMTP_HOST=
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_FROM=alerts@example.com
ALERTMANAGER_SMTP_USER=
ALERTMANAGER_SMTP_PASSWORD=
ALERTMANAGER_SMTP_REQUIRE_TLS=true

KEYCLOAK_PORT=9080
OPA_PORT=9181
MONGODB_PORT=27017
INSTRUCTION_PORT=9000
PAYMENT_PORT=9093
OFAC_PORT=9096
# OFAC SLO breach demo mutants (set mode to latency, completion, or both)
OBSERVABILITY_MESH_OFAC_MUTANT_MODE=off
# OBSERVABILITY_MESH_OFAC_MUTANT_MODE=both
# OBSERVABILITY_MESH_OFAC_MUTANT_PAYMENT_ID_PREFIX=SLO-BREACH
# OBSERVABILITY_MESH_OFAC_MUTANT_UNABLE_TO_DETERMINE_PERCENT=15
# OBSERVABILITY_MESH_OFAC_MUTANT_MIN_SCAN_DELAY_MS=90000
# OBSERVABILITY_MESH_OFAC_MUTANT_MAX_SCAN_DELAY_MS=120000
AUTHORIZATION_PORT=9094
SEQUENCE_PORT=9095
DEMO_HARNESS_PORT=9091
