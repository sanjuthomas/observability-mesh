PORT_BLOCK=0

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8889
PROMETHEUS_PORT=9092
TEMPO_PORT=3200
GRAFANA_PORT=3000
